# Configurações Gerais
ENV=development
PROJECT_NAME="JurisSync API"

# CORS: origens permitidas separadas por vírgula.
# Use "*" apenas em desenvolvimento; em produção liste os domínios explícitos.
# Ex: BACKEND_CORS_ORIGINS=https://app.exemplo.com,https://admin.exemplo.com
BACKEND_CORS_ORIGINS=*

# Banco de Dados
DATABASE_URL=sqlite+aiosqlite:///./juris_sync.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/jurissync_prod

# Segurança e Autenticação (JWT)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# DataJud (CNJ) - Sprint 3
# Sem chave: motor opera em modo mock determinístico
DATAJUD_API_KEY=
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br

# RAG opcional (enriquecimento local; LLM só se OPENAI_API_KEY estiver definida)
RAG_TOP_K=3
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
